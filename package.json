{
  "name": "superhive",
  "version": "0.1.8",
  "description": "Superhive Desktop App",
  "author": "Superhive",
  "main": "dist-electron/main.js",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rishi-ie/superhive"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "bun run build && electron-builder",
    "electron:preview": "vite build && electron .",
    "migrate:keys": "bun scripts/migrate-agent-keys.ts",
    "wipe:agents": "bun scripts/wipe-agents.ts",
    "install:pi": "bun scripts/install-manifest-pi.ts",
    "reset": "bun scripts/reset-superhive.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.15",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@shadcn/react": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.6.2",
    "lowdb": "^7.0.1",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
