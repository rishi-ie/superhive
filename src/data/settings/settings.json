        "customEndpointUrl": ""
      },
      {
        "id": "anthropic",
        "label": "Anthropic",
        "apiKey": "",
        "fallbackOrder": ["opus", "sonnet"],
        "customEndpointUrl": ""
      },
      {
        "id": "google",
        "label": "Google AI",
